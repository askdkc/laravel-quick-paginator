{
    "name": "askdkc/laravel-quick-paginator",
    "description": "Speed up Laravel pagination by caching total counts and skipping repeated count queries.",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Dkc\\LaravelQuickPaginator\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Dkc\\LaravelQuickPaginator\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.2",
        "illuminate/cache": "^12.0|^13.0",
        "illuminate/database": "^12.0|^13.0",
        "illuminate/pagination": "^12.0|^13.0",
        "illuminate/support": "^12.0|^13.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.10",
        "orchestra/testbench": "^10.11|^11.1",
        "pestphp/pest": "^4",
        "pestphp/pest-plugin-laravel": "^4",
        "phpunit/phpunit": "^12"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Dkc\\LaravelQuickPaginator\\CachedPaginationServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {
        "analyse": "phpstan analyse --debug",
        "test": "pest"
    },
    "minimum-stability": "stable"
}
